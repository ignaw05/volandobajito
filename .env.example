# --- Supabase ---------------------------------------------------------------
# Project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=
# Service role key: the worker writes bypassing RLS. Never expose client-side.
SUPABASE_SERVICE_ROLE_KEY=

# --- Layer 1: cached price sweep (Travelpayouts Data API) -------------------
TRAVELPAYOUTS_TOKEN=

# --- Layer 3: real-time verification -----------------------------------------
# Provider for paid verification: searchapi | flightapi (default: searchapi).
# searchapi | flightapi | fli. `fli` is free (reverse-engineered Google
# Flights) and uses searchapi as a paid fallback when SEARCHAPI_KEY is set.
VERIFIER_PROVIDER=searchapi
# Needed for searchapi, or as the fli fallback. The key matching a paid
# provider is required; fli needs no key.
SEARCHAPI_KEY=
# Only needed if VERIFIER_PROVIDER=flightapi.
FLIGHTAPI_KEY=
# Cost cap: PAID verification calls per run. With fli this caps only the
# SearchApi fallback (default: 15).
MAX_VERIFICATIONS_PER_RUN=15
# fli is free, so verify sweeps up to this many candidates per run (default: 80).
FLI_MAX_VERIFICATIONS_PER_RUN=80
# Pause between fli calls, ms — avoids hammering Google from one IP (default: 1500).
FLI_PAUSE_MS=1500

# --- Optional baseline bootstrap ---------------------------------------------
# If set, scripts/bootstrap-baseline.ts seeds typical price ranges for the
# top routes via SerpApi. Omit to skip the bootstrap entirely.
SERPAPI_KEY=

# --- Telegram -----------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
# Private chat ID of the human curator. The curation bot ignores everyone else.
CURATOR_CHAT_ID=
# Public channel: @channelname or -100xxxxxxxxxx
CHANNEL_ID=

# --- Click tracking ------------------------------------------------------------
# Base URL of the Vercel redirect function, e.g. https://go.yourdomain.com
REDIRECT_BASE_URL=

# --- Operation ------------------------------------------------------------------
# true = scan+detect only; verification and all notifications disabled.
# Keep true during the first 1-2 weeks of production to accumulate baseline.
# Defaults to true when unset (when in doubt, publish nothing).
SILENT_MODE=true
# true = a verified deal the curator does not reject within 5 minutes is
# published automatically by the curation bot (requires the bot running
# 24/7; see README "Auto-publish"). false = every deal needs a manual ✅.
AUTO_PUBLISH=false
